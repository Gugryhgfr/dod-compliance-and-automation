      File="/var/log/vmware/statsmon/statsmoitor-alarms.log"
      Tag="statsmoitor-alarms"
      Severity="info"
      Facility="local0"
      deleteStateOnFileDelete="on"
      reopenOnTruncate="on")
      #StatsMonitor
